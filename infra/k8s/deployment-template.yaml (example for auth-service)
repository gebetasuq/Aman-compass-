apiVersion: apps/v1
kind: Deployment
metadata:
  name: auth-service
  namespace: aman-compass
spec:
  replicas: 2
  selector:
    matchLabels:
      app: auth-service
  template:
    metadata:
      labels:
        app: auth-service
    spec:
      containers:
      - name: auth-service
        image: amancompassacr.azurecr.io/auth-service:latest
        ports:
        - containerPort: 3001
        envFrom:
        - secretRef:
      
