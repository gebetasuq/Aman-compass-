class ServiceItem {
  final String id;
  final String title;
  final String description;
  final String? link;
  bool isFavorite;

  ServiceItem({
    required this.id,
    required this.title,
    required this.description,
    this.link,
    this.isFavorite = false,
  });
}

class Category {
  final String name;
  final List<ServiceItem> items;
  Category(this.name, this.items);
}

